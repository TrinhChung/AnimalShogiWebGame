{
  "name": "web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "bot-bridge": "node server/native_bot_bridge.mjs",
    "benchmark:import": "node scripts/import_benchmark.mjs",
    "dataset:export": "node scripts/export_training_dataset.mjs",
    "dataset:validate": "node scripts/validate_training_data.mjs",
    "build": "run-p type-check \"build-only {@}\" --",
    "build:wasm": "wasm-pack build ../quantum-animal-shogi/crates/wasm --target web --out-dir ../../../web/src/wasm --release && node -e \"require('node:fs').rmSync('src/wasm/.gitignore', { force: true })\"",
    "preview": "vite preview",
    "build-only": "vite build",
    "test:smoke": "node scripts/smoke_test.mjs",
    "test:report-seed": "node scripts/report_seed_test.mjs",
    "test:bridge": "node --test server/native_bot_bridge.test.mjs",
    "test:database": "node --test server/database.test.mjs server/benchmark_repository.test.mjs server/trajectory_integrity.test.mjs server/training_data_repository.test.mjs server/import_legacy_history.test.mjs scripts/export_training_dataset.test.mjs",
    "test:repository": "node --test server/match_repository.test.mjs",
    "test:tournament": "node --test server/seeded_tournament.test.mjs",
    "test:native-bots": "node scripts/native_bot_smoke_test.mjs",
    "type-check": "vue-tsc --build",
    "lint": "eslint . --fix --cache",
    "format": "prettier --write --experimental-cli src/"
  },
  "dependencies": {
    "mysql2": "^3.23.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.31"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "~10.8.0",
    "jiti": "^2.6.1",
    "npm-run-all2": "^8.0.4",
    "prettier": "3.8.1",
    "typescript": "~6.0.0",
    "vite": "^8.0.3",
    "vue-tsc": "^3.2.6"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
